# ── Desubscribe configuration ───────────────────────────────────────────────
# Copy to `.env` and fill in. The app runs in DEMO MODE with none of these set.

# Local SQLite database (no server needed)
DATABASE_URL="file:./dev.db"

# 32+ char secret used to encrypt mailbox/Plaid credentials at rest.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ── Claude (AI extraction + cancel strategy) ────────────────────────────────
ANTHROPIC_API_KEY=""
# High-volume email extraction. Deeper cancel research uses claude-opus-4-8.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Google OAuth (Gmail read+send + Calendar reminders) ─────────────────────
# Create an OAuth client (Web) in Google Cloud Console; add the redirect URI below.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
APP_URL="http://localhost:3000"

# ── Plaid (bank/card recurring-charge detection) ────────────────────────────
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"            # sandbox | production

# ── Tavily (looks up how to cancel a given merchant) ────────────────────────
TAVILY_API_KEY=""

# ── Multi-currency ──────────────────────────────────────────────────────────
# Totals are shown in this base currency (also settable in the UI).
# Live FX uses api.frankfurter.dev (allow that host in egress); else an
# approximate offline fallback table is used.
BASE_CURRENCY="USD"

# ── Automation ──────────────────────────────────────────────────────────────
# full_auto | draft_only | auto_marketing  (you chose full_auto)
AUTOMATION_LEVEL="full_auto"
# Subscriptions costing more than this still ask before auto-cancel (0 = never ask)
AUTO_CANCEL_CONFIRM_OVER="0"

# ── Scheduled sync + weekly digest ──────────────────────────────────────────
# Point a scheduler at POST /api/cron (runs sync, then emails the digest), e.g.:
#   0 9 * * 1  curl -s -X POST http://localhost:3000/api/cron -H "x-cron-secret: $CRON_SECRET"
# If set, requests to /api/cron must send this in the x-cron-secret header.
CRON_SECRET=""
# Where the digest is sent (defaults to your first connected mailbox).
# Set via Settings or here is not read directly — stored as a DB setting "digestEmail".
